# Backend
# Use `APP_MODE=assessment` for the interview path once OpenAI and Pinecone credentials are ready.
APP_MODE=dev
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_PIPELINE_MODEL=gpt-5-mini
OPENAI_ROUTING_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60.0
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=nvidia-rag
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nvidia-agentic-rag
LANGSMITH_TRACING=false
TAVILY_API_KEY=
USE_PINECONE=false
USE_TAVILY_FALLBACK=false
EMBEDDER_PROVIDER=keyword
# Assessment mode typically uses:
# USE_PINECONE=true
# USE_TAVILY_FALLBACK=true
# EMBEDDER_PROVIDER=openai
# LANGSMITH_TRACING=true
KNOWLEDGE_BASE_ROOT=data/knowledge_base
KNOWLEDGE_BASE_MANIFEST_PATH=data/knowledge_base/manifest.json
RAW_DOC_ROOT=data/knowledge_base/raw
NORMALIZED_DOC_ROOT=data/knowledge_base/normalized
DEMO_KNOWLEDGE_BASE_PATH=data/demo_chunks.json
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
