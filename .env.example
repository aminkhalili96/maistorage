# Backend
# Use `APP_MODE=assessment` for the interview path once Gemini and Pinecone credentials are ready.
APP_MODE=dev
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=3072
GEMINI_DOCUMENT_TASK_TYPE=RETRIEVAL_DOCUMENT
GEMINI_QUERY_TASK_TYPE=RETRIEVAL_QUERY
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=nvidia-rag
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nvidia-agentic-rag
LANGSMITH_TRACING=false
TAVILY_API_KEY=
USE_PINECONE=false
USE_TAVILY_FALLBACK=false
EMBEDDER_PROVIDER=keyword
# Assessment mode typically uses:
# USE_PINECONE=true
# USE_TAVILY_FALLBACK=true
# EMBEDDER_PROVIDER=google
# LANGSMITH_TRACING=true
CORPUS_ROOT=data/corpus
CORPUS_MANIFEST_PATH=data/corpus/manifest.json
RAW_DOC_ROOT=data/corpus/raw
NORMALIZED_DOC_ROOT=data/corpus/normalized
DEMO_CORPUS_PATH=data/demo_chunks.json
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
